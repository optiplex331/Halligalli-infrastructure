{
  "apiVersion": "argoproj.io/v1alpha1",
  "kind": "Application",
  "metadata": {
    "name": "halligalli",
    "namespace": "argocd",
    "labels": {
      "app.kubernetes.io/name": "halligalli",
      "app.kubernetes.io/part-of": "aks",
      "halligalli.games/phase": "validation-run"
    },
    "annotations": {
      "halligalli.games/desired-state-owner": "Halligalli-infrastructure",
      "halligalli.games/image-policy": "digest-pinned-paired-release",
      "halligalli.games/public-entry": "operation-time-ingress-host"
    }
  },
  "spec": {
    "project": "default",
    "sources": [
      {
        "repoURL": "https://github.com/optiplex331/Halligalli-infrastructure.git",
        "targetRevision": "main",
        "path": "gitops/aks/chart/halligalli",
        "helm": {
          "releaseName": "halligalli",
          "valueFiles": [
            "$values/gitops/aks/values/halligalli.values.json"
          ]
        }
      },
      {
        "repoURL": "https://github.com/optiplex331/Halligalli-infrastructure.git",
        "targetRevision": "main",
        "ref": "values"
      }
    ],
    "destination": {
      "server": "https://kubernetes.default.svc",
      "namespace": "halligalli"
    },
    "syncPolicy": {
      "automated": {
        "prune": true,
        "selfHeal": true,
        "allowEmpty": false
      },
      "syncOptions": [
        "CreateNamespace=true",
        "PruneLast=true"
      ]
    },
    "revisionHistoryLimit": 10
  }
}
