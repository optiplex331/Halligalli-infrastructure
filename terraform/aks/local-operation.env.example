# Public template for a local AKS Validation Run Terraform operation.
# Do not put real values in Git. Copy this file to an ignored local path
# such as terraform/aks/local-operation.env and fill it locally.
#
# Do not run apply, destroy, controller bootstrap, Argo CD sync, or DNS movement
# until the human owner explicitly confirms the AKS Validation Run.

HALLIGALLI_AKS_TERRAFORM_OPERATION="plan"

AZURE_TENANT_ID="00000000-0000-0000-0000-000000000000"
AZURE_SUBSCRIPTION_ID="00000000-0000-0000-0000-000000000000"

HCP_TERRAFORM_ORGANIZATION="example-org"
HCP_TERRAFORM_WORKSPACE="aks"

HALLIGALLI_AKS_REGION="westeurope"
HALLIGALLI_AKS_DOMAIN_NAME="halligalli.games"
HALLIGALLI_AKS_INGRESS_SUBDOMAIN="play"
HALLIGALLI_AKS_RESOURCE_GROUP_NAME="halligalli-boss-practice-aks-rg"
HALLIGALLI_AKS_CLUSTER_NAME="halligalli-aks"
HALLIGALLI_AKS_NODE_RESOURCE_GROUP_NAME="halligalli-aks-nodes-rg"
HALLIGALLI_AKS_DNS_PREFIX="halligalli-aks"
HALLIGALLI_AKS_KUBERNETES_VERSION=""
