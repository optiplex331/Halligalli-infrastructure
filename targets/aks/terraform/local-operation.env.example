# Public template for the one ignored AKS preflight configuration.
# Copy to targets/aks/terraform/local-operation.env and fill it locally. A successful
# preflight and plan never authorize apply or any other cloud mutation.

HALLIGALLI_OPERATION_APPROVED="0"
AZURE_SUBSCRIPTION_ID="00000000-0000-0000-0000-000000000000"
HCP_TERRAFORM_ORGANIZATION="example-org"
HCP_TERRAFORM_WORKSPACE="aks"
HALLIGALLI_AKS_KUBERNETES_VERSION="1.XX.Y"
